{
  "name": "telegram-user",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Личный Telegram (MTProto): БД, internal API для агента, заглушки коннектора",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "worker": "node scripts/run-connector-worker.mjs",
    "start": "node --import tsx src/server.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "cabinet-ui:dev": "npm run dev --prefix cabinet-ui",
    "test:automation-prompt": "tsx scripts/test-automation-prompt.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "build:landing": "npm run build --prefix ../prepromo-landing && node ../prepromo-landing/scripts/sync-to-telegram-public.mjs",
    "verify:local": "node scripts/verify-local.mjs"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "prisma": "^6.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "grammy": "^1.42.0",
    "jose": "^6.2.2",
    "openid-client": "^5.6.5"
  }
}
