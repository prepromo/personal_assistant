# Скопируйте в telegram-user/.env

# PostgreSQL (рекомендуется). Локально — поднимите: cd telegram-user && docker compose up -d postgres
# С хоста в контейнер (порт 5433 в docker-compose.yml):
DATABASE_URL=postgresql://tguser:tguser@127.0.0.1:5433/tguser
# В Docker-сети compose (сервис api): postgresql://tguser:tguser@postgres:5432/tguser
PORT=4050

# Длинная случайная строка — ключ AES-256-GCM для sessionEnc (SHA256 от строки)
SESSION_ENCRYPTION_KEY=change-me-to-random-32-chars-minimum

# Общий секрет: Python-коннектор шлёт X-Connector-Secret
CONNECTOR_SECRET=change-me-connector-secret

# API агента: Authorization: Bearer <AGENT_API_TOKEN>
AGENT_API_TOKEN=change-me-agent-token

# Веб-кабинет (JWT HS256, минимум 16 символов)
CABINET_JWT_SECRET=change-me-cabinet-jwt-secret-min-16-chars

# CORS: по умолчанию разрешены http://localhost:5173 и http://127.0.0.1:5173 (Vite cabinet-ui).
# Список через запятую или CORS_ORIGINS=* для любого origin.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- LLM: кабинет + automationProcessor (GigaChat через OpenAI-совместимый API) ---
# В chatCompletion сначала проверяются OPENCLAW_*; если оба заданы — запросы ТОЛЬКО туда (игнор OPENAI_*).
#
# Вариант A — OpenClaw gateway (часто порт 18789). Gateway должен быть ЗАПУЩЕН: openclaw gateway run или openclaw/scripts/start-gateway.ps1
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=токен из ~/.openclaw/openclaw.json (gateway.auth.token)
# Для обычного диалога (без агента): id провайдера/модели из ~/.openclaw/openclaw.json, напр. custom-…/GigaChat. Не openclaw/default — это полный агент.
# OPENCLAW_CHAT_MODEL=custom-gigachat-devices-sberbank-ru/GigaChat
#
# Вариант B — только gpt2giga (GigaChat), без gateway: ЗАКОММЕНТИРУЙТЕ все OPENCLAW_* выше, иначе запросы всё равно пойдут на :18789
# OPENAI_BASE_URL=http://127.0.0.1:8090/v1
# OPENAI_API_KEY=токен от refresh-gigachat / gpt2giga (см. openclaw/README.md)
# OPENAI_CHAT_MODEL=GigaChat
#
# Повтор при 429 (GigaChat): LLM_MAX_ATTEMPTS=4, LLM_RETRY_BASE_MS=2000
# Логи, почему не создали job автоответа: AUTOMATION_SKIP_LOG=1
#
# --- Отчёты владельцу по входящим в чатах, привязанных к ProductAgent (без автоответа собеседнику) ---
# После каждого входящего MTProto-сообщения в таком чате — краткий отчёт в продуктовый бот; при all_steps_done + confidence — кнопка «Отключить агента».
# AGENT_INBOUND_REPORT=1   (выкл: 0 | false | off)
# AGENT_REPORT_MAX_TOKENS=600
# AGENT_REPORT_TEMPERATURE=0.25
# Минимальная уверенность модели (0..1), чтобы показать кнопку отключения агента
# AGENT_REPORT_OFFER_DISABLE_MIN_CONFIDENCE=0.55
# Автоответы (LLM): лимит длины ответа и температура; первая строка исходящего в Telegram
# По умолчанию 1024 токена и 0.4 — удобнее для GigaChat; при необходимости снизьте
# AUTOMATION_MAX_TOKENS=1024
# AUTOMATION_TEMPERATURE=0.4
# AUTOMATION_AGENT_LABEL=Отвечает Агент
# Доп. абзац к системному промпту автоответов (без пересборки кода) — для отладки тона
# AUTOMATION_SYSTEM_APPEND=Например: всегда обращайся на «ты», если так в чате принято.
# История в промпт LLM: full — последние 25 из 40 сообщений; trigger — только входящее сообщение-триггер (меньше влияния «шумного» хвоста). Если строка триггера не найдена в БД — fallback на full.
# AUTOMATION_HISTORY_MODE=full
# AUTOMATION_HISTORY_MODE=trigger
#
# Календарь владельца в system-промпте (pending Reminder + недавние UserNote) — чтобы агент помнил планы при trigger-only.
# AUTOMATION_OWNER_CONTEXT=1   (выкл: 0 | false | off)
# IANA-часовой пояс для подписей времени и извлечения дат во втором проходе LLM
# AUTOMATION_TIMEZONE=Europe/Moscow
#
# После автоответа — второй вызов LLM: извлечь заметку и/или напоминание → UserNote / Reminder (как в API / боте).
# AUTOMATION_PERSIST_ACTIONS=1   (выкл: 0 | false | off)
# AUTOMATION_ACTIONS_MAX_TOKENS=512
# AUTOMATION_ACTIONS_TEMPERATURE=0.1
#
# Проверка «выполнена ли цель агента» по последней реплике собеседника (второй вызов LLM перед ответом).
# Включает подсказку в system промпт и при success: заметка владельцу + аудит; если открыта ровно одна Task — status done.
# AUTOMATION_MISSION_EVAL=1
# AUTOMATION_MISSION_MET_CONFIDENCE=0.65
# AUTOMATION_MISSION_EVAL_MAX_TOKENS=256
# AUTOMATION_MISSION_EVAL_TEMPERATURE=0.1
#
# Отложить напоминание с кнопкой «Ещё нет» в боте (минуты, по умолчанию 60)
# REMINDER_SNOOZE_MINUTES=60
#
# Свободный чат с LLM в личке с продуктовым ботом (тот же chatCompletion, что кабинет)
# PRODUCT_BOT_CHAT_DISABLED=0
# PRODUCT_BOT_CHAT_MAX_TOKENS=1024
# PRODUCT_BOT_CHAT_TEMPERATURE=0.45
# PRODUCT_BOT_CHAT_MAX_MSGS=24
# PRODUCT_BOT_CHAT_LOG=0
# PRODUCT_BOT_CHAT_SYSTEM=   (опционально свой system-промпт целиком)
#
# Шаблоны «Написать первым» (Comrade): перед «Отправить» черновик прогоняется через LLM в короткое сообщение контакту (без копирования мета-инструкций). Отключить: PRODUCT_BOT_COMRADE_POLISH=0
# PRODUCT_BOT_COMRADE_POLISH_MAX_TOKENS=380

# OIDC (опционально): Google и др. — redirect URI должен совпасть с консолью провайдера
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://127.0.0.1:4050/api/v1/auth/oidc/callback
# OIDC_SUCCESS_REDIRECT=/cabinet.html

# --- Продуктовый бот (MVP): пульт задач / чатов / напоминаний (Bot API, без MTProto) ---
# Рекомендуемая схема: токен только здесь; в openclaw/.env TELEGRAM_BOT_TOKEN пустой (gateway = LLM :18789, без второго polling).
# Токен от @BotFather
# PRODUCT_BOT_TOKEN=123456:ABC...
# Имя бота без @ — для ссылок t.me/<name>?start=… (режим чата из **Настройки** → чаты)
# Имя бота без @ — для Telegram Login Widget на сайте (вход без пароля). В @BotFather: /setdomain → ваш домен.
# PRODUCT_BOT_USERNAME=YourBotName
#
# PNG для обучения (фото 1.png … фото 6 воркер.png — см. productCoursePhotos.ts). По умолчанию: ../photos от telegram-user или telegram-user/assets/course-photos
# PRODUCT_BOT_PHOTOS_DIR=D:/Python/Github/VPN_service/photos
#
# Кабинет: тестовая «оплата месяца» без ЮKassa (только для стенда; в проде выключите).
# BILLING_ALLOW_SIMULATED_PAYMENT=1
#
# ЮKassa (ЮMoney для бизнеса): помесячная оплата из кабинета (500 ₽ заявлено в продукте).
# В личном кабинете ЮKassa задайте webhook: POST https://<ваш-домен>/api/v1/cabinet/billing/yookassa-webhook
# Опционально проверка запроса: заголовок Authorization: Bearer <секрет> или ?secret= — см. YOOKASSA_WEBHOOK_SECRET
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# Тестовые платежи (поле test:true у создания платежа). Укажите ключи тестового магазина из личного кабинета ЮKassa.
# YOOKASSA_TEST_PAYMENTS=1
# YOOKASSA_WEBHOOK_SECRET=
#
# Публичный URL сервиса (для кнопки «Личный кабинет» в боте: ссылка на cabinet.html).
# Локально по умолчанию http://127.0.0.1:4050; в проде — https://ваш-домен.ru
# PRODUCT_PUBLIC_BASE_URL=http://127.0.0.1:4050
# Альтернативное имя (если задано — то же самое, что PRODUCT_PUBLIC_BASE_URL):
# CABINET_PUBLIC_URL=http://127.0.0.1:4050
# Путь к странице кабинета относительно origin (по умолчанию cabinet.html)
# PRODUCT_CABINET_PATH=cabinet.html
#
# NL: распознавание фраз («создай агента…», напоминание и т.д.) → по умолчанию **сразу выполнение** в чате без кнопки «Подтвердить».
# Для create_agent / task_agent_reminder после NL всегда шаг **выбора чатов** (можно поправить угаданные); при кривом JSON классификатора — «мягкий» черновик и тот же шаг.
# Исходящие в личный Telegram из NL: по умолчанию текст **полируется LLM** и ставится в очередь (worker). Выкл: PRODUCT_BOT_NL_AUTO_OUTBOUND=0
# Без явного first_message: синтез текста из agent_prompt (если ≥20 симв.). Выкл: PRODUCT_BOT_NL_SYNTH_OUTBOUND=0
# Без LLM-полировки (сырой first_message / укороченный prompt): PRODUCT_BOT_NL_OUTBOUND_POLISH=0
# PRODUCT_BOT_NL_OUTBOUND_MAX_TOKENS=400
# Вернуть старый режим с подтверждением и шагом выбора чатов при неясных привязках: PRODUCT_BOT_NL_CONFIRM=1
# PRODUCT_BOT_NL=0
# PRODUCT_BOT_NL_CONFIRM=1
# PRODUCT_BOT_NL_MAX_TOKENS=512
# PRODUCT_BOT_NL_TEMPERATURE=0.1
# polling (локально, без HTTPS) | webhook (нужен публичный URL и setWebhook)
# BOT_MODE=polling
# Для webhook: тот же secret, что передан в setWebhook secret_token
# PRODUCT_BOT_WEBHOOK_SECRET=случайная-строка
#
# Исходящие в личный Telegram через HTTP (кабинет /v1/.../send): по умолчанию запрещены — только подтверждение в боте.
# ALLOW_UNCONFIRMED_HTTP_OUTBOUND=1
#
# Планировщик дайджестов «новостей» (legacy): по умолчанию выключен. Включить: NEWS_DIGEST_ENABLED=1
# NEWS_DIGEST_ENABLED=1
# NEWS_DIGEST_POLL_MS=900000
