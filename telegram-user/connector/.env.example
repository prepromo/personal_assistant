# Скопируйте в connector/.env (рядом с login.py / worker.py)

# https://my.telegram.org — api_id (int) и api_hash
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# UUID пользователя в вашем продукте (например из Comrade User.id)
APP_USER_ID=user-5814732025

# URL API telegram-user (npm run dev)
API_BASE_URL=http://127.0.0.1:4050

# Тот же секрет, что TELEGRAM_USER_CONNECTOR_SECRET в telegram-user/.env
CONNECTOR_SECRET=local-dev-connector-secret-2026

# Опционально: разные имени сессий Pyrogram
# PYROGRAM_SESSION_NAME=tg_user_mvp

# Опционально: auth_server.py (вход по телефону из браузера)
# AUTH_SERVER_PORT=4052
