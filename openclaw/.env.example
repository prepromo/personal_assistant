# Скопируйте в ".env" и заполните. Файл ".env" в .gitignore — не коммитьте.
#   copy .env.example .env

# --- Telegram (бот от @BotFather) ---
# Оставьте пустым, если продуктовый бот только в telegram-user/.env (PRODUCT_BOT_TOKEN) — см. README «Вариант 1».
# Тогда в %USERPROFILE%\.openclaw\openclaw.json нужно channels.telegram.enabled: false (иначе gateway упадёт на пустом секрете).
# Иначе OpenClaw и telegram-user будут делить один токен (pairing, конфликт getUpdates).
TELEGRAM_BOT_TOKEN=

# --- GigaChat (Сбер): ключ авторизации из личного кабинета developers.sber.ru ---
# Формат: Client ID и Client Secret (для Basic auth), либо готовая строка Basic base64 — см. README
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
# Обычно для физлиц: GIGACHAT_API_PERS
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# gpt2giga (Python): при [SSL: CERTIFICATE_VERIFY_FAILED] к API Сбера — явно false; на Windows без этой строки скрипт подставит false
# GIGACHAT_VERIFY_SSL_CERTS=false

# После scripts/refresh-gigachat-token.ps1 сюда же можно вручную не писать —
# скрипт выведет OPENAI_API_KEY на 30 минут. Для стабильной работы см. прокси gpt2giga в README.

# --- gpt2giga (локальный OpenAI->GigaChat прокси; по умолчанию включён) ---
# Установка: .\scripts\install-gpt2giga.ps1
USE_GPT2GIGA_PROXY=true
GPT2GIGA_PORT=8090
# USE_GPT2GIGA_PROXY=false — прямой OAuth в GigaChat (короткий токен), без gpt2giga

# --- OpenAI-совместимый слой для OpenClaw (подставляется скриптом или вручную) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=http://127.0.0.1:8090/v1

# Windows + GigaChat: Node должен доверять корневым сертификатам ОС (иначе TLS к api сбер)
NODE_OPTIONS=--use-system-ca

# --- Comrade (бэкенд в этом репо) читает этот файл первым, затем comrade/backend/.env ---
# Тот же Bearer, что для gateway (gateway.auth.token в ~/.openclaw/openclaw.json)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_CHAT_MODEL=GigaChat

# --- telegram-user API (v1 задачи / привязка; скилл invoke.ps1) ---
# Скопируйте AGENT_API_TOKEN из telegram-user/.env
TELEGRAM_USER_BASE_URL=http://127.0.0.1:4050
TELEGRAM_USER_AGENT_TOKEN=

# Опционально: уровень логов
# OPENCLAW_LOG_LEVEL=debug
