# Порт веб-портала (не конфликтуйте с telegram-user 4050 и gpt2giga 8090)
PORT=3090

# Секрет сессии (любая длинная строка для локалки)
SESSION_SECRET=local-dev-saas-secret-change-me-32chars-min

# OpenAI-совместимый слой = gpt2giga (после start-gpt2giga.ps1)
LLM_OPENAI_BASE_URL=http://127.0.0.1:8090/v1
# При GPT2GIGA_ENABLE_API_KEY_AUTH=False можно любой непустой ключ
LLM_API_KEY=sk-local-saas-dev

# Вход отключён по умолчанию. Чтобы тестировать логин: LOCAL_SAAS_SKIP_AUTH=0 и npm run seed:test-user
# LOCAL_SAAS_SKIP_AUTH=0

# Опционально: полноценный агент OpenClaw (как в telegram-user / openclaw gateway)
# Скопируйте из %USERPROFILE%\.openclaw\openclaw.json (gateway.port, gateway.auth.token) или из openclaw/.env
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_CHAT_MODEL=openclaw/default

# Опционально: URL health для telegram-user (страница статусов /api/status)
# TELEGRAM_USER_HEALTH_URL=http://127.0.0.1:4050/health
