# Backend (скопируйте в comrade/backend/.env)
# Локально по умолчанию — SQLite (без Docker). Для PostgreSQL см. README.
DATABASE_URL=file:./dev.db
PORT=4000
JWT_SECRET=change-me-long-random
APP_SECRET=change-me-different-long-random

# Шифрование токенов каналов (можно совпадать с JWT_SECRET только в dev)
# APP_SECRET=

# Оплата: true = заглушка (MVP, без ЮKassa). Для прод: false + ключи ниже
BILLING_STUB=true

# ЮKassa — https://yookassa.ru/developers (при BILLING_STUB=false)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_AMOUNT=299.00

# URL фронта (return после оплаты, CORS)
FRONTEND_URL=http://localhost:5173

# Webhook ЮKassa: укажите публичный URL вида https://your-domain/api/billing/yookassa/webhook

# OpenClaw — gateway должен быть запущен; в ~/.openclaw/openclaw.json включите:
# gateway.http.endpoints.chatCompletions.enabled = true
# Токен gateway (если пусто — бэкенд подставит из %USERPROFILE%\.openclaw\ при старте)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
# Модель для OpenClaw gateway: openclaw/default (агент; GigaChat внутри него в openclaw.json)
OPENCLAW_CHAT_MODEL=custom-gigachat-devices-sberbank-ru/GigaChat
OPENCLAW_MODEL=
AUTOMATION_HISTORY_MODE=trigger
# Frontend (опционально, для прод за прокси)
# VITE_API_URL=https://api.example.com
